# ═══════════════════════════════════════════════════════════════════════════
# DEPLOYMENT ENVIRONMENT VARIABLES
# Copy ini ke Environment Variables di Portainer Stack
# ═══════════════════════════════════════════════════════════════════════════

# ── n8n Integration ──────────────────────────────────────────────────────────
# N8N_WEBHOOK_URL: Untuk fetch komentar dari URL (scraping via n8n)
# Kosongkan untuk menggunakan sample data
N8N_WEBHOOK_URL=

# N8N_AI_WEBHOOK_URL: Untuk AI review komentar ambiguous
# Format: https://your-n8n.app.n8n.cloud/webhook/ai-review
N8N_AI_WEBHOOK_URL=https://n8n.technokh.com/webhook/ai-review

# ── Anthropic AI (untuk Python service) ──────────────────────────────────────
# Dibutuhkan kalau AI review langsung dari Python (bukan via n8n)
ANTHROPIC_API_KEY=sk-ant-api03-xxx

# ═══════════════════════════════════════════════════════════════════════════
# NOTES:
# - PYTHON_SERVICE_URL di-set otomatis di docker-compose (http://analysis-service:8000)
# - Port 3000: Next.js Web App
# - Port 8000: Python Analysis Service (bisa di-comment di docker-compose kalau tidak perlu publik)
# ═══════════════════════════════════════════════════════════════════════════
