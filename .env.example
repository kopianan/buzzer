# ── Python Analysis Service ─────────────────────
PYTHON_SERVICE_URL=http://localhost:8000

# ── n8n Integration ─────────────────────────────
# N8N_WEBHOOK_URL: Untuk fetch komentar dari URL (scraping via n8n)
# Kosongkan untuk menggunakan sample data
N8N_WEBHOOK_URL=

# N8N_AI_WEBHOOK_URL: Untuk AI review komentar ambiguous
# Format: https://your-n8n.app.n8n.cloud/webhook/ai-review
N8N_AI_WEBHOOK_URL=

# Contoh:
# N8N_WEBHOOK_URL=https://your-n8n.app.n8n.cloud/webhook/fetch-comments
# N8N_AI_WEBHOOK_URL=https://your-n8n.app.n8n.cloud/webhook/ai-review

# ── Internal API Key (shared secret antara Next.js & Python) ──
# Generate random string, contoh: openssl rand -hex 32
INTERNAL_API_KEY=your-random-secret-key

# ── Firebase Admin SDK (Server-side) ────────────
# Dapatkan dari Firebase Console > Project Settings > Service Accounts > Generate new private key
# Download JSON, lalu copy nilai-nilai berikut:
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
# PENTING: Ganti \n literal dengan \\n saat paste ke .env.local
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ── Firebase Configuration (Client-side) ────────
# Dapatkan dari Firebase Console > Project Settings > General > Your Apps > Web App
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef123456

# Untuk mendapatkan config:
# 1. Buka https://console.firebase.google.com
# 2. Buat project baru atau pilih project existing
# 3. Klik gear icon ⚙️ > Project settings
# 4. Di tab "General", scroll ke "Your apps" > Web App
# 5. Klik "Add app" atau copy config dari app yang sudah ada
